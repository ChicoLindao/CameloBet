rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      // Profile creation only on login, balance updates only via system increment (for now we allow user to update if balance change is negative or strictly controlled)
      allow create: if isOwner(userId) && request.resource.data.balance == 500.00;
      allow update: if isOwner(userId) 
        && request.resource.data.email == resource.data.email
        && request.resource.data.uid == resource.data.uid;
    }

    // 2. Matches Collection
    match /matches/{matchId} {
      allow read: if true; // Publicly readable
    }

    // 3. Bets Collection
    match /bets/{betId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.amount > 0
        && request.resource.data.amount <= get(/databases/$(database)/documents/users/$(request.auth.uid)).data.balance;
    }
  }
}
